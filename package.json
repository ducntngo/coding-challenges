{
  "name": "real-time-quiz-service",
  "version": "0.1.0",
  "private": true,
  "description": "Foundation scaffold for the real-time quiz challenge backend.",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "bootstrap": "bash scripts/bootstrap.sh",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/ws": "8.18.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "ws": "8.20.0"
  },
  "dependencies": {
    "@fastify/websocket": "11.2.0",
    "fastify": "5.8.4"
  }
}
